{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SuperMemo PARA",
  "version": "1.0.0",
  "identifier": "com.hansenre.supermemopara",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "node server.js",
    "devUrl": "http://127.0.0.1:5050",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SuperMemo PARA",
        "url": "http://127.0.0.1:5050",
        "width": 1366,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": {
      "../server.js": "app/server.js",
      "../public": "app/public",
      "../node_modules": "app/node_modules",
      "../package.json": "app/package.json"
    }
  }
}
